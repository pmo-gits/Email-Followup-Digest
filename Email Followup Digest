// ─────────────────────────────────────────────
// CONSTANTS
// ─────────────────────────────────────────────
var SHEET_DIGEST   = 'Digest';
var SHEET_CONFIG   = 'Config';
var DATA_START_ROW = 4; // Row 1: Meta, Row 2: Blank, Row 3: Headers, Row 4: Data

// ─────────────────────────────────────────────
// WEB APP ENTRY POINT — doGet
// Execute as: PMO (pmo@butlerleather.com)
// Access: Anyone in organisation
// ─────────────────────────────────────────────
function doGet(e) {
  try {
    Logger.log('doGet called.');

    // Authorization check — reads sender email from Config (not hardcoded)
    var authResult = checkAuthorization();
    if (!authResult.authorized) {
      return ContentService
        .createTextOutput(JSON.stringify({ status: 'error', message: authResult.message }))
        .setMimeType(ContentService.MimeType.JSON);
    }

    // Run core digest logic
    runFollowupDigest();

    return ContentService
      .createTextOutput(JSON.stringify({ status: 'success', message: 'Followup Digest refreshed successfully.' }))
      .setMimeType(ContentService.MimeType.JSON);

  } catch (e) {
    Logger.log('doGet ERROR: ' + e.message);
    return ContentService
      .createTextOutput(JSON.stringify({ status: 'error', message: e.message }))
      .setMimeType(ContentService.MimeType.JSON);
  }
}

// ─────────────────────────────────────────────
// AUTHORIZATION CHECK
// Reads sender email from Config — no hardcoding
// PMO = sender email in config → always runs
// Other user = must match sender email → runs
// No match → UI Alert — not authorized
// ─────────────────────────────────────────────
function checkAuthorization() {
  try {
    var ss         = SpreadsheetApp.getActiveSpreadsheet();
    var config     = readConfig(ss);
    var senderEmail = config.senderEmail.toLowerCase().trim();
    var currentUser = Session.getActiveUser().getEmail().toLowerCase().trim();

    Logger.log('Auth check — Current user: ' + currentUser + ' | Sender email: ' + senderEmail);

    if (currentUser === senderEmail) {
      Logger.log('Authorization passed.');
      return { authorized: true };
    }

    // Not authorized
    Logger.log('Authorization FAILED for: ' + currentUser);
    return {
      authorized : false,
      message    : 'You are not authorized to run this script.\n\nYour email: ' + currentUser + '\nAuthorized email: ' + senderEmail
    };

  } catch (e) {
    Logger.log('checkAuthorization ERROR: ' + e.message);
    return { authorized: false, message: 'Authorization check failed: ' + e.message };
  }
}

