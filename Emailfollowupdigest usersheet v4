// ─────────────────────────────────────────────
// SETUP DAILY TRIGGER
// ─────────────────────────────────────────────
function setupDailyTrigger() {
  try {
    removeDailyTrigger();

    var ss          = SpreadsheetApp.getActiveSpreadsheet();
    var config      = readConfig(ss);
    var triggerHour = 8;

    var timeStr   = config.triggerTime || '8:00 AM';
    var timeParts = timeStr.match(/(\d+):(\d+)\s*(AM|PM)/i);
    if (timeParts) {
      triggerHour = parseInt(timeParts[1]);
      if (timeParts[3].toUpperCase() === 'PM' && triggerHour !== 12) triggerHour += 12;
      if (timeParts[3].toUpperCase() === 'AM' && triggerHour === 12) triggerHour = 0;
    }

    ScriptApp.newTrigger('runFollowupDigest')
      .timeBased()
      .everyDays(1)
      .atHour(triggerHour)
      .create();

    Logger.log('Trigger set at hour: ' + triggerHour);
    SpreadsheetApp.getActiveSpreadsheet().toast(
      'Daily trigger set at ' + config.triggerTime,
      '✅ Trigger Setup Done', 5
    );

  } catch (e) {
    Logger.log('setupDailyTrigger ERROR: ' + e.message);
    SpreadsheetApp.getUi().alert('❌ Trigger Error', e.message, SpreadsheetApp.getUi().ButtonSet.OK);
  }
}

// ─────────────────────────────────────────────
// REMOVE DAILY TRIGGER
// ─────────────────────────────────────────────
function removeDailyTrigger() {
  try {
    var triggers = ScriptApp.getProjectTriggers();
    for (var i = 0; i < triggers.length; i++) {
      if (triggers[i].getHandlerFunction() === 'runFollowupDigest') {
        ScriptApp.deleteTrigger(triggers[i]);
        Logger.log('Trigger removed.');
      }
    }
    SpreadsheetApp.getActiveSpreadsheet().toast(
      'Daily trigger removed.',
      '🗑️ Trigger Removed', 5
    );
  } catch (e) {
    Logger.log('removeDailyTrigger ERROR: ' + e.message);
  }
}

// ─────────────────────────────────────────────
// EXTRACT RECIPIENTS — Max 2 emails + count
// ─────────────────────────────────────────────
function extractRecipients(toField) {
  try {
    if (!toField) return '';
    var parts  = toField.split(',');
    var emails = [];

    for (var i = 0; i < parts.length; i++) {
      var part  = parts[i].trim();
      var match = part.match(/<([^>]+)>/);
      if (match) {
        emails.push(match[1].trim());
      } else if (part.indexOf('@') !== -1) {
        emails.push(part.trim());
      }
    }

    if (emails.length === 0) return toField.trim();
    if (emails.length === 1) return emails[0];
    if (emails.length === 2) return emails[0] + ', ' + emails[1];

    var remaining = emails.length - 2;
    return emails[0] + ', ' + emails[1] + ' +' + remaining + ' more';

  } catch (e) {
    Logger.log('extractRecipients ERROR: ' + e.message);
    return toField || '';
  }
}

// ─────────────────────────────────────────────
// EXTRACT NAME — from last sent To field
// ─────────────────────────────────────────────
function extractName(toField) {
  try {
    if (!toField) return '';
    var firstPart  = toField.split(',')[0].trim();
    var match      = firstPart.match(/^([^<]+)</);
    if (match) return match[1].trim();
    var emailMatch = firstPart.match(/<([^>]+)>/);
    if (emailMatch) return emailMatch[1].split('@')[0].trim();
    return firstPart.split('@')[0].trim();
  } catch (e) {
    return '';
  }
}
