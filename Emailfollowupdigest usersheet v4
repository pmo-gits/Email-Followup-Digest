// ─────────────────────────────────────────────
// CONSTANTS
// ─────────────────────────────────────────────
var SHEET_DIGEST      = 'Digest';
var SHEET_CONFIG      = 'Config';
var SHEET_SNOOZE_LIST = 'Snooze_List';
var DATA_START_ROW    = 4;
var CENTRAL_URL       = 'https://script.google.com/macros/s/AKfycbxINb7Xqp87uemx1ptHtQ4a-ggDcTmcG1Lhdj3IJJwfXDW0t8E71mOkKvq2hp0hR4iaQg/exec';

// ─────────────────────────────────────────────
// COLUMN POSITIONS — Digest Tab (1-based)
// Thread ID | Recipient | Recipient Name | Subject |
// Sent Date | Days Elapsed | Category | Gmail Link |
// Snooze | Remarks
// ─────────────────────────────────────────────
var COL_THREAD_ID      = 1;  // A — Script (once)
var COL_RECIPIENT      = 2;  // B — Script (refresh)
var COL_RECIPIENT_NAME = 3;  // C — Script (refresh)
var COL_SUBJECT        = 4;  // D — Script (once)
var COL_SENT_DATE      = 5;  // E — Script (refresh)
var COL_DAYS_ELAPSED   = 6;  // F — Script (refresh)
var COL_CATEGORY       = 7;  // G — Script (refresh)
var COL_GMAIL_LINK     = 8;  // H — Script (once)
var COL_SNOOZE         = 9;  // I — User (dropdown)
var COL_REMARKS        = 10; // J — User (free text, never touched)

// ─────────────────────────────────────────────
// SNOOZE_LIST COLUMN POSITIONS (1-based)
// Read-only from UserSheet — writes go via PMO Central
// ─────────────────────────────────────────────
var SCOL_THREAD_ID  = 1; // A
var SCOL_SUBJECT    = 2; // B
var SCOL_RECIPIENT  = 3; // C
var SCOL_SNOOZED_ON = 4; // D
var SCOL_REMARKS    = 5; // E

